# Amadeus API Credentials
# Get yours at: https://developers.amadeus.com
AMADEUS_CLIENT_ID=seu_amadeus_client_id_aqui
AMADEUS_CLIENT_SECRET=seu_amadeus_client_secret_aqui

# Server Configuration
PORT=5000
NODE_ENV=development

# Privy App Secret (server-side only — NEVER expose this in the frontend)
PRIVY_APP_SECRET=seu_privy_app_secret_aqui

# ─── Stellar & Soroban ──────────────────────────────────────────────────────
# Network: 'testnet' or 'public'
STELLAR_NETWORK=testnet

# Soroban RPC endpoint
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Contract ID of the deployed Soroban Escrow (filled after: stellar contract deploy)
SOROBAN_CONTRACT_ID=

# Oracle keypair — this account signs release_funds transactions
# Generate: stellar keys generate oracle --network testnet --fund
# Get secret: stellar keys show oracle
ORACLE_SECRET_KEY=

# Stellar address of the travel agency that receives USDC after ticket issuance
AGENCY_ADDRESS=